# 2026-04-18 12:39:03.745558
+Patch uniquement main_v5.py.
+
+Objectif:
+intégrer un pipeline local FeatureEngine + RegimeEngine dans la boucle symbole, avec fallback robuste vers le regime global actuel.
+
+Contraintes strictes:
+- Ne modifier aucun autre fichier.
+- Utiliser les noms exacts déjà présents dans ce repo.
+- Import mémoire actuel inchangé: from memory.sharedmemory import SharedMemory
+- Méthodes mémoire à utiliser:
+  - getadvancedfeatures(symbol)
+  - updateadvancedfeatures(symbol, features)
+  - getregimeforsymbol(symbol)
+  - updateregimeforsymbol(symbol, regime)
+  - updateorderbooksnapshot(symbol, snapshot)
+- Utiliser FeatureEngine.compute(...)
+- Utiliser RegimeEngine.assess(..., previousregime=...)
+- Ne pas introduire de nouvelles variantes snake_case si le repo utilise déjà les alias existants.
+- Logs à ajouter avec les clés réelles:
+  - slopealignmentscore
+  - volatilitystate
+  - microtrend
+  - orderbookimbalance
+  - scalpreadinessscore
+
+À faire:
+1. Ajouter les imports:
+   from agents.feature_engine import FeatureEngine
+   from agents.regime_engine import RegimeEngine
+
+2. Dans __init__, instancier:
+   self.featureengine = FeatureEngine(self.memory, self.exchange)
+   self.regimeengine = RegimeEngine(self.memory)
+
+3. Ajouter une petite méthode helper dans la classe:
+   def getorderbooksnapshot(self, symbol: str) -> Dict:
+       try:
+           snapshot = self.orderbook.analyze(symbol) or {}
+           if isinstance(snapshot, dict):
+               return snapshot
+       except Exception as e:
+           logger.warning("ORDERBOOK SNAPSHOT %s error %r", symbol, e)
+       return {}
+
+4. Dans runforever, juste après:
+   tech = self.technical.analyze(symbol) or {}
+insérer:
+   symbolregime = regime
+   try:
+       snapshot = self.getorderbooksnapshot(symbol)
+       if snapshot:
+           self.memory.updateorderbooksnapshot(symbol, snapshot)
+       previousfeatures = self.memory.getadvancedfeatures(symbol) or {}
+       features = self.featureengine.compute(
+           symbol,
+           technical=tech,
+           orderbook=snapshot,
+           regime=regime,
+           previous=previousfeatures,
+       )
+       self.memory.updateadvancedfeatures(symbol, features)
+       previoussymbolregime = self.memory.getregimeforsymbol(symbol) or {}
+       symbolregime = self.regimeengine.assess(
+           symbol,
+           features,
+           previousregime=previoussymbolregime,
+       )
+       self.memory.updateregimeforsymbol(symbol, symbolregime)
+       logger.info(
+           "FEATURE PIPELINE %s slope=%.3f vol=%s micro=%s ob=%.3f scalp=%.2f",
+           symbol,
+           float(features.get("slopealignmentscore", 0.0) or 0.0),
+           str(features.get("volatilitystate", "unknown")),
+           str(features.get("microtrend", "unknown")),
+           float(features.get("orderbookimbalance", 0.0) or 0.0),
+           float(features.get("scalpreadinessscore", 0.0) or 0.0),
+       )
+       logger.info(
+           "REGIME PIPELINE %s trend=%s vol=%s risk=%s",
+           symbol,
+           str(symbolregime.get("trend", "unknown")),
+           str(symbolregime.get("volatility", "medium")),
+           str(symbolregime.get("risk", "medium")),
+       )
+   except Exception as e:
+       logger.warning("PIPELINE V5.9 %s fallback regime global error %r", symbol, e)
+       symbolregime = regime
+
+5. Remplacer ensuite:
+   bull = self.bull.analyze(symbol, regime, tech)
+   bear = self.bear.analyze(symbol, regime, tech)
+par:
+   bull = self.bull.analyze(symbol, symbolregime, tech)
+   bear = self.bear.analyze(symbol, symbolregime, tech)
+
+6. Remplacer ensuite:
+   prices = self.scalper.decide(symbol, side, tech, regime, cons)
+par:
+   prices = self.scalper.decide(symbol, side, tech, symbolregime, cons)
+
+7. Ajouter un log de démarrage dans runforever:
+   logger.info("Pipeline V5.9 active: FeatureEngine + RegimeEngine")
+
+Important:
+- Patch minimal.
+- Pas de refonte.
+- Préserver cooldown, trailing, flip, TPSL, sizing.
+- Fais directement le patch sur main_v5.py, pas seulement une explication.

